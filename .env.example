# Backend
DATABASE_URL=postgresql+asyncpg://rudapt:rudapt@postgres:5432/rudapt
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-please-use-openssl-rand-hex-32
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=60
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGINS=http://localhost:3000

# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_PROVIDER=anthropic            # anthropic | openai
LLM_MODEL_ANTHROPIC=claude-opus-4-7
LLM_MODEL_OPENAI=gpt-4o

# Scrapers
PRODUCTHUNT_TOKEN=                # https://api.producthunt.com (optional, иначе RSS)

# Frontend (frontend/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:8000
